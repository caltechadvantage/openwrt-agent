"""Example per-deployment overrides for the openwrt agent.

Copy this file to ``local_settings.py`` (which is gitignored) and fill
in the values for your tenant. The bottom of ``settings.py`` does a
``from local_settings import *`` so anything you assign here
overrides the default in ``settings.py``.

REQUIRED for a fresh install: ``TB_PROVISION_KEY`` and
``TB_PROVISION_SECRET``. Without them, the agent logs an error on
first boot and won't onboard to ThingsBoard. An already-provisioned
unit (one with a ``tb_token`` in ``~/.openwrt/config.json``) keeps
running without them — the keys are only used the first time.

EVERYTHING else here is optional; the agent has sensible behaviour
when each is unset.
"""

# === ThingsBoard provisioning (REQUIRED for fresh installs) =================
# Generate fresh values for each tenant under TB's "Device Provisioning"
# tile. Same key/secret is reused across every device in the same
# tenant; rotating it invalidates *every* unit's ability to onboard
# until they're updated.
TB_PROVISION_KEY    = "REPLACE_WITH_TENANT_KEY"
TB_PROVISION_SECRET = "REPLACE_WITH_TENANT_SECRET"
# TB_SERVER_URL       = "https://tb.your-domain.example"

# === Bondix Prometheus (optional — per-channel telemetry) ===================
# Only matters if you run a Bondix tunnel and want per-channel latency
# / packet loss / uptime on the dashboard. Without these, the agent
# falls back to per-WAN ping stats and the bondix.channels tab is empty.
# BONDIX_SERVER_URL  = "https://bondix.your-domain.example/metrics"
# BONDIX_SERVER_USER = "prometheus"
# BONDIX_SERVER_PASS = "REPLACE_WITH_BONDIX_SCRAPE_PASSWORD"

# === DTS-MobileQ dual-publish (optional — migration window) =================
# Set these when you're moving a tenant off the legacy ThingsBoard
# dashboard onto the in-house DTS dashboard. The agent then mirrors
# every telemetry frame onto the DTS broker AND keeps publishing to TB
# until the cutover is final.
# MQTT_BROKER_HOST     = "mqtt.dts.your-domain.example"
# MQTT_BROKER_PORT     = 1883
# MQTT_BROKER_USERNAME = "agent"
# MQTT_BROKER_PASSWORD = "REPLACE_WITH_BROKER_PASSWORD"
# DTS_HTTP_URL         = "https://dts.your-domain.example"

# === Agent behaviour ========================================================
# Telemetry interval in seconds. Lower = more granular dashboard but
# more cellular traffic if the WAN uplink is metered.
# INTERVAL = 30

# Ngrok auto-stop seconds. The dashboard's Start ngrok button always
# arms an auto-shutdown so a tunnel left open after a debugging
# session doesn't run forever.
# NGROK_DURATION = 1800
