# Per-fleet provisioning secret for setup.sh (ensure_provision_keys).
#
# Copy this file to bootstrap.local.env (same dir) and fill in your
# tenant's ThingsBoard provisioning key/secret. bootstrap.local.env is
# gitignored and MUST NOT be committed -- it mints devices against the
# tenant. Ship it on your golden image / build host so a fleet install
# stays zero-touch, the same way scripts/bootstrap.env carries the
# shared ngrok token (the difference: THIS file never enters git).
#
# setup.sh sources this only as a fallback: an already-present
# local_settings.py or exported TB_PROVISION_* env vars take priority.
# Find the values in ThingsBoard: Device profiles > <profile> >
# Device provisioning.

TB_PROVISION_KEY="REPLACE_WITH_TENANT_KEY"
TB_PROVISION_SECRET="REPLACE_WITH_TENANT_SECRET"
